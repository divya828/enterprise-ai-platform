# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# --- Virtual envs / uv ---
.venv/
venv/
.python-version.local

# --- Secrets / local config ---
.env
.env.local
*.local

# --- Data, model caches, generated artifacts ---
# Ignore everything under data/ EXCEPT the .gitkeep marker and the synthetic
# corpus fixtures (regenerable via scripts/generate_corpus.py; committed because
# tests + the eval harness depend on them). Runtime artifacts like the embedded
# Qdrant store stay ignored.
data/*
!data/.gitkeep
!data/corpus/
data/corpus/*
!data/corpus/documents.json
!data/corpus/golden.json
*.sqlite
*.sqlite3
*.db
qdrant_storage/
.cache/
models/
.huggingface/
hf_cache/

# --- Test / tooling caches ---
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
.mypy_cache/

# --- Editor / OS ---
.idea/
.vscode/
.DS_Store
