# Copy this file to `.env` and adjust. `.env` is gitignored — never commit secrets.
# All settings are read by src/eaip/config/settings.py (pydantic-settings).
# Every value below is OPTIONAL: the defaults make the platform run fully
# offline with no API key and no model installed.

# ---------------------------------------------------------------------------
# LLM provider selection
# ---------------------------------------------------------------------------
# One of: stub | ollama | anthropic | openai
#   stub      -> deterministic, offline, zero-dependency. DEFAULT. Used by all
#                unit tests + CI. CI must NEVER call a live LLM.
#   ollama    -> local models via http://localhost:11434 (free, but small models
#                handle multi-step tool use poorly).
#   anthropic -> Claude (needs ANTHROPIC_API_KEY). Best agent behavior.
#   openai    -> GPT (needs OPENAI_API_KEY).
EAIP_LLM_PROVIDER=stub

# Model name passed to the selected provider (ignored by the stub).
EAIP_LLM_MODEL=claude-opus-4-8

# ---------------------------------------------------------------------------
# Provider credentials / endpoints (only needed for the matching provider)
# ---------------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
EAIP_OLLAMA_BASE_URL=http://localhost:11434

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
EAIP_DATA_DIR=./data
EAIP_LOG_LEVEL=INFO
